# Google Calendar Integration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/callback

# Frontend URL (For redirecting back after OAuth)
FRONTEND_URL=http://localhost:3000

# OpenAI Integration
OPENAI_API_KEY=your_openai_api_key_here

# App Secrets
SECRET_KEY=supersecretkey_change_in_production

# Database URL
DATABASE_URL=postgresql://postgres:admin@localhost:5432/landingforge

# Storage Configuration
STORAGE_PROVIDER=local

# AWS S3 Settings
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# Google Cloud Storage Settings
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json
GCS_BUCKET_NAME=your-gcs-bucket-name

# SMTP Email (for Automations - Send Email action)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Your Agency <your_email@gmail.com>
